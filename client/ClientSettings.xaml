<UserControl x:Class="client.ClientSettings"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:client"
             mc:Ignorable="d" 
             d:DesignHeight="450" 
             d:DesignWidth="800"
             Background="#2B2A33"
             Loaded="UserControl_Loaded"
             MouseLeftButtonDown="UserControl_MouseLeftButtonDown">

    <Canvas Name="MainCanva">

        <!-- Icona di uscita -->
        <Image Name="ExitSettingsIcon" 
               Source="/assets/icons/left_arrow.png" 
               Height="32" Width="32" 
               Canvas.Top="20" Canvas.Left="25"
               MouseLeftButtonDown="ExitSettingsIcon_MouseLeftButtonDown"/>

        <!-- Titolo del server -->
        <TextBox x:Name="ServerTitle" 
                 TextWrapping="NoWrap" 
                 Text="Server" 
                 IsReadOnly="True" 
                 Width="148" 
                 Canvas.Left="41" Canvas.Top="57" 
                 Background="Transparent" 
                 Foreground="WhiteSmoke" 
                 FontFamily="Segoe UI SemiBold" 
                 FontWeight="SemiBold" 
                 FontSize="22" 
                 BorderThickness="0" 
                 IsHitTestVisible="False" 
                 HorizontalAlignment="Left" 
                 VerticalAlignment="Center"/>

        <!-- Sottotitolo -->
        <TextBox x:Name="ServerCotitle" 
                 TextWrapping="NoWrap" 
                 Text="Set your server preferences" 
                 IsReadOnly="True" 
                 Width="181" 
                 Canvas.Left="41" Canvas.Top="89" 
                 Background="Transparent" 
                 Foreground="#A9A9A9" 
                 FontFamily="Segoe UI"  
                 FontSize="15" 
                 BorderThickness="0" 
                 IsHitTestVisible="False" 
                 HorizontalAlignment="Left" 
                 VerticalAlignment="Center"/>

        <!-- Etichetta per l'indirizzo IP remoto -->
        <Label Name="RemoteIpLabel" 
               Content="Address:" 
               Foreground="#A9A9A9" 
               Canvas.Left="324" 
               FontSize="13" 
               Canvas.Top="58"/>

        <!-- TextBox per l'IP remoto -->
        <TextBox Name="RemoteIpTextbox"
                 Background="Transparent"
                 CaretBrush="NavajoWhite"
                 TextAlignment="Center"
                 VerticalContentAlignment="Center"
                 SelectionBrush="#7160E8"
                 BorderThickness="1.5"
                 TextWrapping="NoWrap"
                 Canvas.Left="324"
                 Canvas.Top="89"
                 Width="154"
                 Height="30"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center"
                 Foreground="White"
                 FocusVisualStyle="{x:Null}">

            <TextBox.Style>
                <Style TargetType="TextBox">
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderThickness" Value="1.5"/>
                    <Setter Property="TextAlignment" Value="Center"/>
                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TextBox">
                                <Border Name="Border"
                                        CornerRadius="5"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="#5F5F5F"
                                        BorderThickness="{TemplateBinding BorderThickness}">
                                    <ScrollViewer Margin="0"
                                                  x:Name="PART_ContentHost"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <!-- Cambia il bordo a viola quando la TextBox ha il focus -->
                                    <Trigger Property="IsKeyboardFocused" Value="True">
                                        <Setter TargetName="Border" Property="BorderBrush" Value="#7160E8"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TextBox.Style>

        </TextBox>

        <!-- Etichetta per la porta -->
        <Label x:Name="RemotePortLabel" 
            Content="Port:" 
            Foreground="#A9A9A9" 
            Canvas.Left="521" 
            FontSize="13" 
            Canvas.Top="58" HorizontalAlignment="Left" VerticalAlignment="Center"/>

        <!-- TextBox per la porta -->
        <TextBox x:Name="RemotePortTextbox"
                 Background="Transparent"
                 CaretBrush="NavajoWhite"
                 TextAlignment="Center"
                 VerticalContentAlignment="Center"
                 SelectionBrush="#7160E8"
                 BorderThickness="1.5"
                 TextWrapping="NoWrap"
                 Canvas.Left="521"
                 Canvas.Top="93"
                 Width="154"
                 Height="30"
                 Foreground="White"
                 FocusVisualStyle="{x:Null}" 
                 HorizontalAlignment="Left" 
                 VerticalAlignment="Top">

            <TextBox.Style>
                <Style TargetType="{x:Type TextBox}">
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderThickness" Value="1.5"/>
                    <Setter Property="TextAlignment" Value="Center"/>
                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="{x:Type TextBox}">
                                <Border x:Name="Border"
                                        CornerRadius="5"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="#5F5F5F"
                                        BorderThickness="{TemplateBinding BorderThickness}">
                                    <ScrollViewer Margin="0"
                                                  x:Name="PART_ContentHost"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <!-- Cambia il bordo a viola quando la TextBox ha il focus -->
                                    <Trigger Property="IsKeyboardFocused" Value="True">
                                        <Setter TargetName="Border" Property="BorderBrush" Value="#7160E8"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TextBox.Style>

        </TextBox>

        <!-- Etichetta per il nome utente -->
        <Label x:Name="RemoteUsernameLabel" 
            Content="Username:" 
            Foreground="#A9A9A9" 
            Canvas.Left="324" 
            FontSize="13" 
            Canvas.Top="136" 
            HorizontalAlignment="Center" 
            VerticalAlignment="Top"/>

        <!-- TextBox per il nome utente -->
        <TextBox x:Name="RemoteUsernameTextBox"
                 Background="Transparent"
                 CaretBrush="NavajoWhite"
                 TextAlignment="Center"
                 VerticalContentAlignment="Center"
                 SelectionBrush="#7160E8"
                 BorderThickness="1.5"
                 TextWrapping="NoWrap"
                 Canvas.Left="324"
                 Canvas.Top="171"
                 Width="154"
                 Height="30"
                 Foreground="White"
                 FocusVisualStyle="{x:Null}" 
                 HorizontalAlignment="Center" 
                 VerticalAlignment="Top">

            <TextBox.Style>
                <Style TargetType="{x:Type TextBox}">
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderThickness" Value="1.5"/>
                    <Setter Property="TextAlignment" Value="Center"/>
                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="{x:Type TextBox}">
                                <Border x:Name="Border"
                                        CornerRadius="5"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="#5F5F5F"
                                        BorderThickness="{TemplateBinding BorderThickness}">
                                    <ScrollViewer Margin="0"
                                                  x:Name="PART_ContentHost"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <!-- Cambia il bordo a viola quando la TextBox ha il focus -->
                                    <Trigger Property="IsKeyboardFocused" Value="True">
                                        <Setter TargetName="Border" Property="BorderBrush" Value="#7160E8"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TextBox.Style>

        </TextBox>

        <!-- Etichetta per la password -->
        <Label x:Name="RemotePasswdLabel" 
            Content="Password:" 
            Foreground="#A9A9A9" 
            Canvas.Left="521" 
            FontSize="13" 
            Canvas.Top="136" 
            HorizontalAlignment="Left" 
            VerticalAlignment="Top"/>

        <!-- TextBox per la password -->
        <TextBox x:Name="RemotePasswordTextbox"
                 Background="Transparent"
                 CaretBrush="NavajoWhite"
                 TextAlignment="Center"
                 VerticalContentAlignment="Center"
                 SelectionBrush="#7160E8"
                 BorderThickness="1.5"
                 TextWrapping="NoWrap"
                 Canvas.Left="521"
                 Canvas.Top="171"
                 Width="154"
                 Height="30"
                 Foreground="White"
                 FocusVisualStyle="{x:Null}" 
                 HorizontalAlignment="Left" 
                 VerticalAlignment="Center">

            <TextBox.Style>
                <Style TargetType="{x:Type TextBox}">
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderThickness" Value="1.5"/>
                    <Setter Property="TextAlignment" Value="Center"/>
                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="{x:Type TextBox}">
                                <Border x:Name="Border"
                                        CornerRadius="5"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="#5F5F5F"
                                        BorderThickness="{TemplateBinding BorderThickness}">
                                    <ScrollViewer Margin="0"
                                                  x:Name="PART_ContentHost"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <!-- Cambia il bordo a viola quando la TextBox ha il focus -->
                                    <Trigger Property="IsKeyboardFocused" Value="True">
                                        <Setter TargetName="Border" Property="BorderBrush" Value="#7160E8"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TextBox.Style>

        </TextBox>

        <Image Name="Logo" Source="/assets/icons/resistenza_purple_logo.png" Height="253" Width="334" Canvas.Left="404" Canvas.Top="36" />
        <Line Name="FirstSeparator" Stroke="#3D3D3D" StrokeThickness="0.6" Canvas.Top="150" />
        <TextBox x:Name="LoggingCotitle" 
            TextWrapping="NoWrap" 
            Text="Enable or disable logging" 
            IsReadOnly="True" 
            Width="181" 
            Canvas.Left="41" Canvas.Top="205" 
            Background="Transparent" 
            Foreground="#A9A9A9" 
            FontFamily="Segoe UI"  
            FontSize="15" 
            BorderThickness="0" 
            IsHitTestVisible="False" 
                 HorizontalAlignment="Center" VerticalAlignment="Top" />
        <TextBox x:Name="LoggingLabel" 
            TextWrapping="NoWrap" 
            Text="Logging" 
            IsReadOnly="True" 
            Width="148" 
            Canvas.Left="41" Canvas.Top="176" 
            Background="Transparent" 
            Foreground="WhiteSmoke" 
            FontFamily="Segoe UI SemiBold" 
            FontWeight="SemiBold" 
            FontSize="22" 
            BorderThickness="0" 
            IsHitTestVisible="False" 
                 HorizontalAlignment="Center" VerticalAlignment="Top"/>
        <Label x:Name="BuildVersionLabel" 
            Content="" 
            Foreground="Gray"
            
            FontSize="11" 
            />

        <CheckBox Name="LoggingCheckbox" Content="Enable Logging" Foreground="#A9A9A9" FontSize="13" Canvas.Left="100" Canvas.Top="100">
            <CheckBox.Style>
                <Style TargetType="CheckBox">
                    <Setter Property="Background" Value="#8A2BE2"/>
                    <!-- Colore viola di base -->
                    <Setter Property="BorderBrush" Value="#6A3A99"/>
                    <!-- Colore del bordo -->
                    <Setter Property="BorderThickness" Value="2"/>
                    <Style.Triggers>
                        <!-- Trigger quando il mouse è sopra la CheckBox -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#8A2BE2"/>
                            <!-- Mantiene lo stesso colore viola -->
                        </Trigger>
                        <!-- Trigger quando la CheckBox è selezionata -->
                        <Trigger Property="IsChecked" Value="True">
                            <Setter Property="Background" Value="#8A2BE2"/>
                            <!-- Mantiene lo stesso colore viola -->
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </CheckBox.Style>
        </CheckBox>








    </Canvas>
</UserControl>
